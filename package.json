{
	"name": "n8n-nodes-minimax-chat",
	"version": "0.1.1",
	"description": "MiniMax Chat Model node for n8n - Use MiniMax AI models in your n8n workflows",
	"license": "MIT",
	"homepage": "https://github.com/davidtaoweiji/n8n-nodes-minimax-chat#readme",
	"keywords": [
		"n8n",
		"n8n-community-node-package",
		"minimax",
		"ai",
		"chat"
	],
	"author": {
		"name": "taowei ji",
		"email": "caramel@minimaxi.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/davidtaoweiji/n8n-nodes-minimax-chat.git"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"aiNodeSdkVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/MiniMaxApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/MiniMaxChatModel/MiniMaxChatModel.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"eslint": "9.32.0",
		"prettier": "3.6.2",
		"release-it": "^19.0.4",
		"typescript": "5.9.2"
	},
	"peerDependencies": {
		"n8n-workflow": "*",
		"@n8n/ai-node-sdk": "*"
	}
}
